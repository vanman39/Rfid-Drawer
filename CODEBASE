#include <SPI.h>
#include <MFRC522.h>
#include <ESP32Servo.h>

#define RST_PIN 22
#define SS_PIN 5
#define SERVO_PIN 12
#define BUTTON_PIN 14
#define LEDPIN 15

MFRC522 mfrc522(SS_PIN, RST_PIN);
Servo myServo;

byte authorizedUID[4]; 
bool isLearned = false; // Tracks if we have saved a card yet

void setup() {
  Serial.begin(115200);
  SPI.begin(18, 19, 23, 5);
  mfrc522.PCD_Init();
  
  myServo.setPeriodHertz(50);
  myServo.attach(SERVO_PIN);
  myServo.write(123); // Start Locked
  
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  pinMode(LEDPIN, OUTPUT);
  digitalWrite(LEDPIN, LOW);

  Serial.println("System Ready.");
  Serial.println("Waiting for you to swipe the card to LEARN it...");
}

void loop() {
  if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
    
    if (!isLearned) {
      // LEARNING MODE: Save the first card it sees
      for (byte i = 0; i < 4; i++) {
        authorizedUID[i] = mfrc522.uid.uidByte[i];
      }
      isLearned = true;
      Serial.println("Card Learned and Saved!");
    } else {
      // OPERATING MODE: Check against saved card
      bool match = true;
      for (byte i = 0; i < 4; i++) {
        if (mfrc522.uid.uidByte[i] != authorizedUID[i]) {
          match = false;
          break;
        }
      }

      if (match) {
        Serial.println("Authorized! unlocking...");
        myServo.write(0); // unLocked
        digitalWrite(LEDPIN, HIGH);
      } else {
        Serial.println("Access Denied!");
      }
    }
    mfrc522.PICC_HaltA();
  }

  if (digitalRead(BUTTON_PIN) == LOW) {
    Serial.println("locking...");
    digitalWrite(LEDPIN, LOW);
    myServo.write(123);
    delay(200);
  }
}
