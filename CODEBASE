#include <SPI.h>
#include <MFRC522.h>
#include <ESP32Servo.h>

// PIN DEFINITIONS
#define RST_PIN 22
#define SS_PIN 5
#define SERVO_PIN 12    // Servo on GPIO 12
#define BUTTON_PIN 14   // Button on GPIO 14

MFRC522 mfrc522(SS_PIN, RST_PIN);
Servo myServo;

void setup() {
  Serial.begin(115200);
  SPI.begin(18, 19, 23, 5); 
  mfrc522.PCD_Init();
  
  myServo.setPeriodHertz(50);
  myServo.attach(SERVO_PIN);
  myServo.write(0); // Start closed
  
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  
  Serial.println("System Ready. Swipe to open, press button to close.");
}

void loop() {
  // 1. RFID Logic: Open and hold
  if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
    Serial.println("Card detected! Opening drawer...");
    myServo.write(90); // Opens and stays at 90
    mfrc522.PICC_HaltA();
  }

  // 2. Button Logic: Close when pressed
  if (digitalRead(BUTTON_PIN) == LOW) {
    Serial.println("Button pressed: Closing drawer.");
    myServo.write(0);  // Returns to 0
    delay(200);        // Debounce delay
  }
}
