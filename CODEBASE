#include <SPI.h>
#include <MFRC522.h>
#include <ESP32Servo.h>

#define RST_PIN 4
#define SS_PIN 5
#define SERVO_PIN 13
#define BUTTON_PIN 14

MFRC522 mfrc522(SS_PIN, RST_PIN);
Servo myServo;

void setup() {
  Serial.begin(115200);
  SPI.begin();
  mfrc522.PCD_Init();
  myServo.attach(SERVO_PIN);
  myServo.write(0);
  Serial.println("Drawer ready \n");
  pinMode(BUTTON_PIN, INPUT_PULLUP);
}

void loop() {
  if (!mfrc522.PICC_IsNewCardPresent()) {
    return;
  }
  Serial.println("Access granted!");
  myServo.write(90);
  if (digitalRead(BUTTON_PIN) == LOW) {
    myServo.write(0);
    Serial.println("closed with button \n");
    delay(200);
  }
  
}


